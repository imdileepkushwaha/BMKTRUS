        <div id="admLoader" class="adm-loader" aria-hidden="true" role="status">
            <div class="adm-loader-card">
                <div class="adm-loader-ring">
                    <span class="adm-loader-dot"></span>
                </div>
                <p class="adm-loader-title">Please wait</p>
                <p class="adm-loader-text">Loading your request…</p>
            </div>
        </div>

        <script type="text/javascript" src="../sarah/assets/plugins/jquery/jquery-2.1.4.min.js"></script>
        <script src="../bower_components/bootstrap/dist/js/bootstrap.min.js"></script>
        <script src="../bower_components/jquery-slimscroll/jquery.slimscroll.min.js"></script>
        <script src="../bower_components/fastclick/lib/fastclick.js"></script>
        <script src="../dist/js/adminlte.min.js"></script>
        <script>
            $(document).ready(function () {
                if ($('.sidebar-menu').length && typeof $.fn.tree === 'function') {
                    $('.sidebar-menu').tree();
                }
                var path = window.location.pathname.toLowerCase();
                var file = path.substring(path.lastIndexOf('/') + 1);
                if (!file) file = 'dashboard.aspx';
                $('.sidebar-menu a').each(function () {
                    var href = ($(this).attr('href') || '').toLowerCase();
                    if (href && href !== '#' && file === href) {
                        $(this).parent('li').addClass('active');
                        $(this).closest('.treeview').addClass('active menu-open');
                        $(this).closest('.treeview-menu').show();
                    }
                });
                if (file === 'dashboard.aspx') {
                    $('.sidebar-menu > li').has('a[href="Dashboard.aspx"]').addClass('active');
                }
                var uname = $.trim($('.adm-user-trigger-name').text());
                if (uname) {
                    $('.adm-dd-name').text(uname);
                }
                function enhanceContentHeaders() {
                    $('.content-header > h1').each(function () {
                        var $h = $(this);
                        if ($h.hasClass('is-enhanced')) return;
                        var title = $.trim($h.clone().children().remove().end().text());
                        if (!title) title = $.trim($h.text());
                        $h.addClass('is-enhanced').html(
                            '<span class="adm-ch-icon"><i class="fa fa-tachometer"></i></span>' +
                            '<span class="adm-ch-text">' +
                            '<span class="adm-ch-badge">Admin Panel</span>' +
                            '<span class="adm-ch-title"></span>' +
                            '</span>'
                        );
                        $h.find('.adm-ch-title').text(title);
                    });
                }
                function bindAdmFileInput($input) {
                    if ($input.data('adm-file-bound')) return;
                    $input.data('adm-file-bound', true);
                    var $wrap = $input.closest('.adm-file');
                    function syncName() {
                        var file = $input[0].files && $input[0].files[0];
                        var name = file ? file.name : 'No file selected';
                        $wrap.find('.adm-file__name').text(name);
                        $wrap.toggleClass('has-file', !!file);
                        if (file) {
                            $wrap.find('.adm-file__title').text('File ready');
                            $wrap.find('.adm-file__hint').text('Click to replace this file');
                        } else {
                            $wrap.find('.adm-file__title').text('Choose a file');
                            $wrap.find('.adm-file__hint').text('PNG, JPG or PDF — click or drag to upload');
                        }
                    }
                    $input.on('change.admFile', function () {
                        syncName();
                        var previewSel = $input.attr('data-preview');
                        if (previewSel && $input[0].files && $input[0].files[0] && window.FileReader) {
                            var reader = new FileReader();
                            reader.onload = function (e) {
                                $(previewSel).each(function () {
                                    $(this).attr('src', e.target.result).css({ display: 'block', visibility: 'visible' });
                                });
                            };
                            reader.readAsDataURL($input[0].files[0]);
                        }
                    });
                    $input.on('dragenter.admFile dragover.admFile', function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        $wrap.addClass('is-dragover');
                    });
                    $input.on('dragleave.admFile drop.admFile', function () {
                        $wrap.removeClass('is-dragover');
                    });
                    syncName();
                }
                function enhanceFileInputs() {
                    $('.content input[type="file"]').each(function () {
                        var $input = $(this);
                        if (!$input.closest('.adm-file').length) {
                            $input.addClass('adm-file__input').removeClass('form-control');
                            $input.wrap('<div class="adm-file"></div>');
                            $input.after(
                                '<div class="adm-file__ui">' +
                                '<span class="adm-file__icon"><i class="fa fa-cloud-upload"></i></span>' +
                                '<span class="adm-file__body">' +
                                '<span class="adm-file__title">Choose a file</span>' +
                                '<span class="adm-file__hint">PNG, JPG or PDF — click or drag to upload</span>' +
                                '<span class="adm-file__name">No file selected</span>' +
                                '</span>' +
                                '<span class="adm-file__btn">Browse</span>' +
                                '</div>'
                            );
                        } else {
                            $input.addClass('adm-file__input').removeClass('form-control');
                        }
                        bindAdmFileInput($input);
                    });
                }
                function enhanceActionButtons() {
                    $('.content table a, .content .table a').each(function () {
                        var $a = $(this);
                        if ($a.data('adm-action-done') || $a.hasClass('adm-action-btn') || $a.hasClass('adm-action-btn-danger')) {
                            if ($a.hasClass('adm-action-btn') || $a.hasClass('adm-action-btn-danger')) {
                                $a.find('i.fa-pencil-square-o').removeClass('icon fa-pencil-square-o').addClass('fa fa-pencil');
                            }
                            return;
                        }
                        var $editIcon = $a.children('i.fa-pencil-square-o, i.icon.fa-pencil-square-o, i.fa.fa-pencil-square-o');
                        if ($editIcon.length && $.trim($a.text()) === '') {
                            $a.addClass('adm-action-btn').attr('title', $a.attr('title') || 'Edit');
                            $editIcon.removeClass('icon fa-pencil-square-o').addClass('fa fa-pencil');
                            $a.data('adm-action-done', true);
                            return;
                        }
                        var $delIcon = $a.children('i.fa-trash, i.fa-remove, i.fa-times, i.icon.fa-trash, i.icon.fa-remove');
                        if ($delIcon.length && $.trim($a.text()) === '') {
                            $a.addClass('adm-action-btn-danger').attr('title', $a.attr('title') || 'Delete');
                            $delIcon.removeClass('icon').addClass('fa');
                            if ($delIcon.hasClass('fa-remove') || $delIcon.hasClass('fa-times')) {
                                $delIcon.removeClass('fa-remove fa-times').addClass('fa-trash');
                            }
                            $a.data('adm-action-done', true);
                        }
                    });
                }
                enhanceContentHeaders();
                enhanceFileInputs();
                enhanceActionButtons();

                var $admLoader = $('#admLoader');
                function showAdmLoader() {
                    $admLoader.addClass('is-visible').attr('aria-hidden', 'false');
                }
                function hideAdmLoader() {
                    $admLoader.removeClass('is-visible').attr('aria-hidden', 'true');
                }

                $('.adm-sidebar-backdrop').on('click', function () {
                    if ($(window).width() <= 767) {
                        $('body').removeClass('sidebar-open');
                    }
                });
                $(document).on('click', '.main-sidebar .sidebar-menu a[href]:not([href="#"])', function () {
                    if ($(window).width() <= 767) {
                        $('body').removeClass('sidebar-open');
                    }
                });
                if (window.Sys && Sys.WebForms && Sys.WebForms.PageRequestManager) {
                    var prm = Sys.WebForms.PageRequestManager.getInstance();
                    prm.add_beginRequest(function () {
                        showAdmLoader();
                    });
                    prm.add_endRequest(function () {
                        hideAdmLoader();
                        enhanceContentHeaders();
                        enhanceFileInputs();
                        enhanceActionButtons();
                    });
                }
            });
        </script>
        <asp:ContentPlaceHolder ID="contentScript" runat="server"></asp:ContentPlaceHolder>
    </form>
</body>
</html>
