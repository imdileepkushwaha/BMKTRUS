                                <li><a href="FranchiseeReport.aspx"><i class="fa fa-angle-right"></i> Franchisee Report</a></li>
                                <li><a href="FranchiseePurchaseMaster.aspx"><i class="fa fa-angle-right"></i> Product Purchase</a></li>
                                <li><a href="FranchiseePurchaseDetail.aspx"><i class="fa fa-angle-right"></i> Product Purchase Report</a></li>
